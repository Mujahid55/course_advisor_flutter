# --- Required ---
OPENAI_API_KEY=sk-...

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=course_advisor

# --- OpenAI (optional, defaults shown) ---
OPENAI_MODEL=gpt-4o-mini
MAX_TOKENS=800
TEMPERATURE=0.4

# --- File upload (optional) ---
MAX_FILE_BYTES=10485760        # 10 MB

# --- Session management (optional) ---
SESSION_TTL_SECONDS=7200       # expire after 2 h of inactivity
SESSION_CLEANUP_INTERVAL=300   # run cleanup every 5 minutes
MAX_HISTORY_TURNS=10           # conversation turns kept per session

# --- Server (optional) ---
# To restrict CORS to specific origins (JSON list):
# CORS_ORIGINS=["http://localhost:3000","http://192.168.1.x:8080"]
CORS_ORIGINS=["*"]
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
